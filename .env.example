# CDC Warehouse Platform — Environment Configuration
# Copy to .env and fill in values for your environment.
# .env is gitignored — never commit real secrets.

# --- Runtime Profile ---
# dev: local Docker/fallback allowed. prod: real services required, no fallback.
ENVIRONMENT=dev
SPRING_PROFILES_ACTIVE=dev

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=root
MYSQL_DATABASE=cdc_warehouse_admin
MYSQL_PASSWORD=<change-me>

# --- SpringBoot Datasource ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cdc_warehouse_admin
DB_USER=root
DB_PASSWORD=<change-me>

# --- Platform Auth ---
ADMIN_USER=admin
ADMIN_PASS=<change-me>
# Optional multi-user RBAC. If empty, ADMIN_USER/ADMIN_PASS is used.
# Format: username:password:ROLE,username:password:ROLE
# Roles: ADMIN, OPERATOR, VIEWER
AUTH_USERS=
JWT_SECRET=<generate-a-random-256-bit-secret>
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

# --- DolphinScheduler ---
DS_ENDPOINT=http://localhost:12345/dolphinscheduler
DS_TOKEN=<your-dolphinscheduler-api-token>

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=cdc.incremental.binlog

# --- HDFS / Hive ---
LAKE_ROOT=hdfs://hdfs-namenode:8020/warehouse
WAREHOUSE_HDFS_ROOT=hdfs://hdfs-namenode:8020/warehouse
WEBHDFS_ENDPOINT=http://hdfs-namenode:9870
WEBHDFS_USER=hdfs
HIVE_JDBC_URL=jdbc:hive2://hive-server:10000/default
PROGRESS_ROOT=/warehouse/progress
DELAY_GATE_MAX_SECONDS=1800
MERGE_AUDIT_ROOT=data/ops/merge_audit
MERGE_BACKUP_ROOT=hdfs://hdfs-namenode:8020/warehouse/ods_backup

# --- Spark jobs ---
SPARK_MASTER=local[2]
SPARK_KAFKA_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.1
SPARK_STREAMING_CHECKPOINT=hdfs://hdfs-namenode:8020/warehouse/checkpoints/offline_sink
SPARK_STARTING_OFFSETS=latest
SPARK_MAX_OFFSETS_PER_TRIGGER=1000
SPARK_BAD_RECORDS_PATH=hdfs://hdfs-namenode:8020/warehouse/dead_letter/offline_sink
SPARK_STREAMING_INTERVAL_SECONDS=5

# --- Maxwell (CDC) ---
MAXWELL_USER=maxwell
MAXWELL_PASSWORD=<change-me>

# --- Kudu / Impala (optional) ---
IMPALA_JDBC_URL=jdbc:hive2://host.docker.internal:21050/realtime;transportMode=binary;auth=noSasl
IMPALA_HOST=host.docker.internal
IMPALA_PORT=21050
KUDU_MASTERS=host.docker.internal:7051
KUDU_MASTER_URL=http://localhost:8051
IMPALA_UI_URL=http://localhost:25000
USE_REAL_KUDU=false

# --- Alerts ---
ALERT_CHANNELS=file
ALERT_TARGET=dba
ALERT_OUTBOX=data/alerts/outbox.jsonl
DINGTALK_WEBHOOK_URL=
WECHAT_WORK_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
