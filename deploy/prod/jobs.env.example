# Spark/Python jobs production env.
# Copy to jobs.env and source it before submitting jobs.

ENVIRONMENT=prod
PROJECT_ROOT=/opt/cdc-warehouse-platform
BIZ_DT=

SOURCE_MYSQL_MODE=direct
SOURCE_MYSQL_HOST=mysql.prod.example.com
SOURCE_MYSQL_PORT=3306
SOURCE_MYSQL_USER=cdc_reader
SOURCE_MYSQL_PASSWORD=<change-me>

KAFKA_BOOTSTRAP_SERVERS=kafka01.prod.example.com:9092,kafka02.prod.example.com:9092
KAFKA_TOPIC=cdc.incremental.binlog

LAKE_ROOT=hdfs://nameservice1/warehouse
WAREHOUSE_HDFS_ROOT=hdfs://nameservice1/warehouse
WEBHDFS_ENDPOINT=http://namenode.prod.example.com:9870
WEBHDFS_USER=hdfs

PROGRESS_ROOT=hdfs://nameservice1/warehouse/progress
DELAY_GATE_MAX_SECONDS=1800
MERGE_AUDIT_ROOT=data/ops/merge_audit
MERGE_BACKUP_ROOT=hdfs://nameservice1/warehouse/ods_backup

SPARK_MASTER=local[2]
SPARK_KAFKA_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.1
SPARK_STREAMING_CHECKPOINT=hdfs://nameservice1/warehouse/checkpoints/offline_sink
SPARK_STARTING_OFFSETS=latest
SPARK_MAX_OFFSETS_PER_TRIGGER=1000
SPARK_BAD_RECORDS_PATH=hdfs://nameservice1/warehouse/dead_letter/offline_sink
SPARK_SENSITIVE_RULES=metadata/rules/sensitive_columns.json
SPARK_SENSITIVE_ALERT_PATH=hdfs://nameservice1/warehouse/alerts/sensitive
SPARK_STREAMING_INTERVAL_SECONDS=5
REALTIME_STREAMING_CHECKPOINT=hdfs://nameservice1/warehouse/checkpoints/realtime_kudu
REALTIME_MAX_OFFSETS_PER_TRIGGER=5000
REALTIME_STREAMING_ENABLED=false

DS_ENDPOINT=http://dolphinscheduler.prod.example.com:12345/dolphinscheduler
DS_TOKEN=<change-me>

ALERT_CHANNELS=file,email
ALERT_TARGET=dba
ALERT_OUTBOX=/opt/cdc-warehouse-platform/data/alerts/outbox.jsonl
DINGTALK_WEBHOOK_URL=
WECHAT_WORK_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
SMTP_HOST=smtp.prod.example.com
SMTP_PORT=587
SMTP_USER=cdc-alert@example.com
SMTP_PASS=<change-me>
SMTP_FROM=cdc-alert@example.com
SMTP_TO=dba@example.com

IMPALA_JDBC_URL=jdbc:hive2://impala.prod.example.com:21050/realtime;transportMode=binary;auth=noSasl
IMPALA_HOST=impala.prod.example.com
IMPALA_PORT=21050
KUDU_MASTERS=kudu-master01.prod.example.com:7051
KUDU_MASTER_URL=http://kudu-master01.prod.example.com:8051
IMPALA_UI_URL=http://impala.prod.example.com:25000
