# Server deployment env for SpringBoot Admin.
# Install path default: /opt/cdc-warehouse-platform

SPRING_PROFILES_ACTIVE=prod
WAREHOUSE_PROJECT_ROOT=/opt/cdc-warehouse-platform
SERVER_PORT=8080
WAREHOUSE_ACTIONS_PUBLIC_ENABLED=false

DB_HOST=mysql.prod.example.com
DB_PORT=3306
DB_NAME=cdc_warehouse_admin
DB_USER=cdc_admin
DB_PASSWORD=<change-me>

ADMIN_USER=admin
ADMIN_PASS=<change-me>
# Optional multi-user RBAC.
# Format: username:password:ROLE,username:password:ROLE
# Roles: ADMIN, OPERATOR, VIEWER
AUTH_USERS=admin:<change-me>:ADMIN,ops:<change-me>:OPERATOR,viewer:<change-me>:VIEWER
JWT_SECRET=<generate-strong-256-bit-secret>
COOKIE_SECURE=true
COOKIE_SAME_SITE=Lax

DS_ENDPOINT=http://dolphinscheduler.prod.example.com:12345/dolphinscheduler
DS_TOKEN=<change-me>
HIVE_JDBC_URL=jdbc:hive2://hive.prod.example.com:10000
LAKE_ROOT=hdfs://nameservice1/warehouse
WAREHOUSE_HDFS_ROOT=hdfs://nameservice1/warehouse
WEBHDFS_ENDPOINT=http://namenode.prod.example.com:9870
WEBHDFS_USER=hdfs
KAFKA_BOOTSTRAP_SERVERS=kafka01.prod.example.com:9092,kafka02.prod.example.com:9092
KAFKA_TOPIC=cdc.incremental.binlog
IMPALA_JDBC_URL=jdbc:hive2://impala.prod.example.com:21050/realtime;transportMode=binary;auth=noSasl
IMPALA_HOST=impala.prod.example.com
IMPALA_PORT=21050
KUDU_MASTERS=kudu-master01.prod.example.com:7051
KUDU_MASTER_URL=http://kudu-master01.prod.example.com:8051
IMPALA_UI_URL=http://impala.prod.example.com:25000
