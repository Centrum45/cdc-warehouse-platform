{
  "projectName": "cdc_warehouse",
  "processDefinitionName": "warehouse_daily_process",
  "description": "ODS merge -> DIM -> DWD -> DWS -> DWT -> ADS (comment + trade domains)",
  "schedule": "0 30 2 * * ?",
  "tasks": [
    {"name": "delay_gate", "type": "SHELL", "command": "python3 warehouse/jobs/check_delay_gate.py ${biz_dt}"},
    {"name": "ods_merge", "type": "SPARK_SQL", "command": "bash deploy/run_job.sh daily-merge ${biz_dt}"},
    {"name": "warehouse_layers", "type": "SPARK_SQL", "command": "bash deploy/run_job.sh layers ${biz_dt}"}
  ],
  "dependencies": [
    ["delay_gate", "ods_merge"],
    ["ods_merge", "warehouse_layers"]
  ]
}
